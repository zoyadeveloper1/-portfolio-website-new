<!-- Hero Section -->
<section id="hero">
  <div class="hero-bg"></div>
  <div class="particles" id="particles"></div>
  <div class="container hero-content">
    <div class="row align-items-center min-vh-100">
      <div class="col-lg-7">
        <p class="hero-greeting">👋 Hello, I'm</p>
        <h1 class="hero-name">R. Durgadevi</h1>
        <div class="hero-role">
          <span id="typewriter"></span><span class="cursor">|</span>
        </div>
        <p class="hero-desc">
          A passionate Full Stack Developer building modern, 
          responsive web applications with cutting-edge technologies.
        </p>
        <div class="hero-btns">
          <a href="#contact" class="btn-primary-custom">Hire Me →</a>
          <a href="#about" class="btn-secondary-custom">About Me</a>
        </div>
        <div class="hero-stats">
          <div class="stat">
            <h3>5+</h3>
            <p>Projects</p>
          </div>
          <div class="stat">
            <h3>3+</h3>
            <p>Technologies</p>
          </div>
          <div class="stat">
            <h3>1</h3>
            <p>Internship</p>
          </div>
        </div>
      </div>
      <div class="col-lg-5 text-center">
        <div class="hero-image-wrapper">
          <div class="hero-circle">
            <i class="fas fa-code"></i>
          </div>
          <div class="orbit orbit-1">
            <div class="orbit-dot"><i class="fab fa-html5"></i></div>
          </div>
          <div class="orbit orbit-2">
            <div class="orbit-dot"><i class="fab fa-css3-alt"></i></div>
          </div>
          <div class="orbit orbit-3">
            <div class="orbit-dot"><i class="fab fa-js"></i></div>
          </div>
          <div class="orbit orbit-4">
            <div class="orbit-dot"><i class="fab fa-node-js"></i></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

